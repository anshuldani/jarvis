# J.A.R.V.I.S. Environment Variables
# Copy to .env and fill in your keys

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — ElevenLabs for premium voice (get key at elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Whisper model: tiny (fastest) / base (default) / small (best accuracy)
JARVIS_WHISPER_MODEL=base     # tiny/base/small — smaller = faster but less accurate
